# Safaricom Daraja API Credentials
# Get these from https://developer.safaricom.co.ke

# Your Consumer Key from the Daraja portal
DARAJA_CONSUMER_KEY=YOUR_CONSUMER_KEY_HERE

# Your Consumer Secret from the Daraja portal
DARAJA_CONSUMER_SECRET=YOUR_CONSUMER_SECRET_HERE

# The Lipa Na M-Pesa Online Passkey from the Daraja portal
DARAJA_PASSKEY=YOUR_PASSKEY_HERE

# Your M-Pesa Business Shortcode (Paybill or Till number)
# For Sandbox testing, use: 174379
DARAJA_SHORTCODE=174379

# The callback URL that Safaricom will call after payment
# For local dev with ngrok, use something like: https://your-ngrok-url.ngrok-free.app/api/callback
# For now we use a placeholder
CALLBACK_URL=https://mydomain.com/api/callback

# Environment: sandbox or production
DARAJA_ENV=sandbox

# Server port
PORT=5000
